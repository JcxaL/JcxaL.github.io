{
  "$description": "The JccL Line \u2014 design tokens (DTCG-flavored). Source of truth for CSS vars, Tailwind theme, GSAP durations, and MapLibre paint. Build with: pnpm tokens",
  "color": {
    "ground": {
      "0": {
        "$value": "#0a0c10",
        "$description": "station black \u2014 page ground"
      },
      "1": {
        "$value": "#12151c",
        "$description": "panel"
      },
      "2": {
        "$value": "#1b2029",
        "$description": "raised surface / carriage wall"
      },
      "line": {
        "$value": "#2a3140",
        "$description": "hairline dividers"
      }
    },
    "ink": {
      "signage": {
        "$value": "#f2f3f5",
        "$description": "signage white \u2014 primary text"
      },
      "muted": {
        "$value": "#9aa1ac"
      },
      "faint": {
        "$value": "#5c6470"
      },
      "inverse": {
        "$value": "#0a0c10",
        "$description": "text on light/line-color plates"
      }
    },
    "board": {
      "amber": {
        "$value": "#ffb000",
        "$description": "departure-board LED amber \u2014 the site glow"
      },
      "amberDim": {
        "$value": "#7a5500",
        "$description": "unlit LED cells"
      },
      "glow": {
        "$value": "rgba(255, 176, 0, 0.35)",
        "$description": "amber bloom shadow"
      }
    },
    "lines": {
      "a": {
        "$value": "#e2231a",
        "$description": "Line A \u2014 vermillion (MTR Tsuen Wan register)"
      },
      "b": {
        "$value": "#0075c2",
        "$description": "Line B \u2014 harbour blue"
      },
      "c": {
        "$value": "#00a040",
        "$description": "Line C \u2014 jade"
      },
      "d": {
        "$value": "#7d499d",
        "$description": "Line D \u2014 violet"
      },
      "e": {
        "$value": "#009b9b",
        "$description": "Line E \u2014 teal"
      },
      "f": {
        "$value": "#c2186b",
        "$description": "Line F \u2014 magenta"
      }
    },
    "status": {
      "visited": {
        "$value": "#2fbf71",
        "$description": "solid marker, solid route line"
      },
      "progress": {
        "$value": "#ffb000",
        "$description": "pulsing halo (static under reduced motion)"
      },
      "planning": {
        "$value": "#6e7bf2",
        "$description": "hollow marker, dashed route line"
      }
    }
  },
  "motion": {
    "duration": {
      "flap": {
        "$value": "90ms",
        "$description": "single split-flap step \u2014 frame-stepped, not eased"
      },
      "hudBoot": {
        "$value": "400ms"
      },
      "punch": {
        "$value": "250ms",
        "$description": "ticket punch commit"
      },
      "door": {
        "$value": "600ms",
        "$description": "train door open/close"
      },
      "exit": {
        "$value": "150ms",
        "$description": "route exit (ease-in)"
      },
      "enter": {
        "$value": "210ms",
        "$description": "route enter (ease-out, delayed by exit)"
      },
      "cardHover": {
        "$value": "350ms"
      },
      "marquee": {
        "$value": "15s",
        "$description": "dot-matrix marquee loop \u2014 constant velocity (linear)"
      }
    },
    "easing": {
      "trainDecelerate": {
        "$value": "cubic-bezier(0.16, 1, 0.3, 1)",
        "$description": "arrive: fast then settle"
      },
      "trainAccelerate": {
        "$value": "cubic-bezier(0.7, 0, 0.84, 0)",
        "$description": "depart: slow then commit"
      },
      "standard": {
        "$value": "cubic-bezier(0.4, 0, 0.2, 1)"
      }
    }
  },
  "globe": {
    "band": {
      "space": {
        "$value": 3,
        "$description": "z0-3: dotted globe + arcs"
      },
      "continent": {
        "$value": 7,
        "$description": "z3-7: labeled pins, arcs fade"
      },
      "city": {
        "$value": 13,
        "$description": "z7-13: themed city style"
      }
    }
  },
  "layout": {
    "measure": {
      "$value": "68ch",
      "$description": "body text measure"
    },
    "radius": {
      "plate": {
        "$value": "6px",
        "$description": "signage plates"
      },
      "card": {
        "$value": "14px"
      },
      "pill": {
        "$value": "999px"
      }
    }
  },
  "fontStack": {
    "signage": {
      "$value": "var(--font-signage), var(--font-geist-sans), system-ui, sans-serif",
      "$description": "Source Sans 3 \u2014 MTR Myriad register; headings, signs, UI"
    },
    "body": {
      "$value": "var(--font-signage), var(--font-geist-sans), system-ui, sans-serif",
      "$description": "one family, weight-only hierarchy (Airbnb rule)"
    },
    "board": {
      "$value": "var(--font-board), monospace",
      "$description": "Doto \u2014 dot-matrix departure boards only, never body"
    },
    "mono": {
      "$value": "var(--font-geist-mono), ui-monospace, monospace",
      "$description": "telemetry voice: coordinates, dates, codes"
    },
    "$description": "Composed stacks; components may also use the raw next/font vars (--font-signage/--font-board/--font-geist-mono) directly."
  }
}