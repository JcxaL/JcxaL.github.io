{
  "$description": "The JccL Line — design tokens (DTCG-flavored). Source of truth for CSS vars, Tailwind theme, GSAP durations, and MapLibre paint. Build with: pnpm tokens. Tokens with a $light value theme-switch (night default / day service); tokens without one are invariant across both services.",
  "color": {
    "ground": {
      "0": {
        "$value": "#100e17",
        "$light": "#f2f0f7",
        "$description": "page ground — night: deep lilac-charcoal · day: pale lilac paper"
      },
      "1": {
        "$value": "#17151f",
        "$light": "#ffffff",
        "$description": "panel — day panels stay solid for legibility"
      },
      "2": {
        "$value": "#211e2b",
        "$light": "#e8e5f1",
        "$description": "raised surface / carriage wall"
      },
      "line": {
        "$value": "#322d40",
        "$light": "#d9d4e6",
        "$description": "hairline dividers"
      }
    },
    "ink": {
      "signage": {
        "$value": "#f3f2f7",
        "$light": "#191622",
        "$description": "signage ink — primary text"
      },
      "muted": {
        "$value": "#a6a2b4",
        "$light": "#57536a",
        "$description": "secondary text — AA on every ground in both themes"
      },
      "faint": {
        "$value": "#918ca6",
        "$light": "#625d78",
        "$description": "faintest legible ink — 4.5:1+ on every ground (axe AA floor)"
      },
      "inverse": {
        "$value": "#100e17",
        "$description": "INVARIANT — dark text on amber/line-color fills, both themes"
      }
    },
    "accent": {
      "base": {
        "$value": "#b8a1ff",
        "$light": "#6a49d1",
        "$description": "lilac — the interactive/chrome accent: nav, focus, links, active. Text/stroke/border only, never a fill (keeps AA simple)."
      }
    },
    "board": {
      "amber": {
        "$value": "#ffb000",
        "$description": "INVARIANT — departure-board LED amber, the lit-signage material"
      },
      "amberDim": {
        "$value": "#7a5500",
        "$description": "INVARIANT — unlit LED cells"
      },
      "glow": {
        "$value": "rgba(255, 176, 0, 0.35)",
        "$description": "INVARIANT — amber bloom shadow (boards stay lit-dark in both themes)"
      }
    },
    "lines": {
      "a": {
        "$value": "#e2231a",
        "$description": "Line A — vermillion (MTR Tsuen Wan register)"
      },
      "b": {
        "$value": "#0075c2",
        "$description": "Line B — harbour blue"
      },
      "c": {
        "$value": "#00a040",
        "$description": "Line C — jade"
      },
      "d": {
        "$value": "#7d499d",
        "$description": "Line D — violet"
      },
      "e": {
        "$value": "#009b9b",
        "$description": "Line E — teal"
      },
      "f": {
        "$value": "#c2186b",
        "$description": "Line F — magenta"
      }
    },
    "status": {
      "visited": {
        "$value": "#2fbf71",
        "$description": "solid marker, solid route line"
      },
      "progress": {
        "$value": "#ffb000",
        "$description": "pulsing halo (static under reduced motion)"
      },
      "planning": {
        "$value": "#6e7bf2",
        "$description": "hollow marker, dashed route line"
      }
    }
  },
  "motion": {
    "duration": {
      "flap": {
        "$value": "90ms",
        "$description": "single split-flap step — frame-stepped, not eased"
      },
      "hudBoot": {
        "$value": "400ms"
      },
      "punch": {
        "$value": "250ms",
        "$description": "ticket punch commit"
      },
      "door": {
        "$value": "600ms",
        "$description": "train door open/close"
      },
      "exit": {
        "$value": "150ms",
        "$description": "route exit (ease-in)"
      },
      "enter": {
        "$value": "210ms",
        "$description": "route enter (ease-out, delayed by exit)"
      },
      "cardHover": {
        "$value": "350ms"
      },
      "marquee": {
        "$value": "15s",
        "$description": "dot-matrix marquee loop — constant velocity (linear)"
      }
    },
    "easing": {
      "trainDecelerate": {
        "$value": "cubic-bezier(0.16, 1, 0.3, 1)",
        "$description": "arrive: fast then settle"
      },
      "trainAccelerate": {
        "$value": "cubic-bezier(0.7, 0, 0.84, 0)",
        "$description": "depart: slow then commit"
      },
      "standard": {
        "$value": "cubic-bezier(0.4, 0, 0.2, 1)"
      }
    }
  },
  "globe": {
    "band": {
      "space": {
        "$value": 3,
        "$description": "z0-3: dotted globe + arcs"
      },
      "continent": {
        "$value": 7,
        "$description": "z3-7: labeled pins, arcs fade"
      },
      "city": {
        "$value": 13,
        "$description": "z7-13: themed city style"
      }
    }
  },
  "layout": {
    "measure": {
      "$value": "68ch",
      "$description": "body text measure"
    },
    "radius": {
      "plate": {
        "$value": "6px",
        "$description": "signage plates"
      },
      "card": {
        "$value": "14px"
      },
      "pill": {
        "$value": "999px"
      }
    }
  },
  "fontStack": {
    "signage": {
      "$value": "var(--font-signage), var(--font-geist-sans), system-ui, sans-serif",
      "$description": "Source Sans 3 — MTR Myriad register; headings, signs, UI"
    },
    "body": {
      "$value": "var(--font-signage), var(--font-geist-sans), system-ui, sans-serif",
      "$description": "one family, weight-only hierarchy (Airbnb rule)"
    },
    "board": {
      "$value": "var(--font-board), monospace",
      "$description": "Doto — dot-matrix departure boards only, never body"
    },
    "mono": {
      "$value": "var(--font-geist-mono), ui-monospace, monospace",
      "$description": "telemetry voice: coordinates, dates, codes"
    },
    "$description": "Composed stacks; components may also use the raw next/font vars (--font-signage/--font-board/--font-geist-mono) directly."
  },
  "depth": {
    "$description": "Layer Model depth planes (CHARTER §2): perspective + parallax translateZ distances for the 2.5D Parallax layer. Invariant across themes.",
    "perspective": {
      "$value": "1000px",
      "$description": "perspective applied to a parallax rig container"
    },
    "near": {
      "$value": "-120px",
      "$description": "closest parallax plane behind chrome (translateZ)"
    },
    "mid": {
      "$value": "-320px",
      "$description": "mid parallax plane"
    },
    "far": {
      "$value": "-640px",
      "$description": "far parallax plane — deepest before the 3D Stage"
    }
  }
}
