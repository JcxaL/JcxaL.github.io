{
  "$description": "The JccL Line — design tokens (DTCG-flavored). Source of truth for CSS vars, Tailwind theme, GSAP durations, and MapLibre paint. Build with: pnpm tokens",
  "color": {
    "ground": {
      "0": { "$value": "#0a0c10", "$description": "station black — page ground" },
      "1": { "$value": "#12151c", "$description": "panel" },
      "2": { "$value": "#1b2029", "$description": "raised surface / carriage wall" },
      "line": { "$value": "#2a3140", "$description": "hairline dividers" }
    },
    "ink": {
      "signage": { "$value": "#f2f3f5", "$description": "signage white — primary text" },
      "muted": { "$value": "#9aa1ac" },
      "faint": { "$value": "#5c6470" },
      "inverse": { "$value": "#0a0c10", "$description": "text on light/line-color plates" }
    },
    "board": {
      "amber": { "$value": "#ffb000", "$description": "departure-board LED amber — the site glow" },
      "amberDim": { "$value": "#7a5500", "$description": "unlit LED cells" },
      "glow": { "$value": "rgba(255, 176, 0, 0.35)", "$description": "amber bloom shadow" }
    },
    "lines": {
      "a": { "$value": "#e2231a", "$description": "Line A — vermillion (MTR Tsuen Wan register)" },
      "b": { "$value": "#0075c2", "$description": "Line B — harbour blue" },
      "c": { "$value": "#00a040", "$description": "Line C — jade" },
      "d": { "$value": "#7d499d", "$description": "Line D — violet" },
      "e": { "$value": "#009b9b", "$description": "Line E — teal" },
      "f": { "$value": "#c2186b", "$description": "Line F — magenta" }
    },
    "status": {
      "visited": { "$value": "#2fbf71", "$description": "solid marker, solid route line" },
      "progress": { "$value": "#ffb000", "$description": "pulsing halo (static under reduced motion)" },
      "planning": { "$value": "#6e7bf2", "$description": "hollow marker, dashed route line" }
    }
  },
  "font": {
    "signage": { "$value": "var(--font-signage), var(--font-geist-sans), system-ui, sans-serif", "$description": "Source Sans 3 — MTR Myriad register; headings, signs, UI" },
    "body": { "$value": "var(--font-signage), var(--font-geist-sans), system-ui, sans-serif", "$description": "one family, weight-only hierarchy (Airbnb rule)" },
    "board": { "$value": "var(--font-board), monospace", "$description": "Doto — dot-matrix departure boards only, never body" },
    "mono": { "$value": "var(--font-geist-mono), ui-monospace, monospace", "$description": "telemetry voice: coordinates, dates, codes" }
  },
  "motion": {
    "duration": {
      "flap": { "$value": "90ms", "$description": "single split-flap step — frame-stepped, not eased" },
      "hudBoot": { "$value": "400ms" },
      "punch": { "$value": "250ms", "$description": "ticket punch commit" },
      "door": { "$value": "600ms", "$description": "train door open/close" },
      "exit": { "$value": "150ms", "$description": "route exit (ease-in)" },
      "enter": { "$value": "210ms", "$description": "route enter (ease-out, delayed by exit)" },
      "cardHover": { "$value": "350ms" }
    },
    "easing": {
      "trainDecelerate": { "$value": "cubic-bezier(0.16, 1, 0.3, 1)", "$description": "arrive: fast then settle" },
      "trainAccelerate": { "$value": "cubic-bezier(0.7, 0, 0.84, 0)", "$description": "depart: slow then commit" },
      "standard": { "$value": "cubic-bezier(0.4, 0, 0.2, 1)" }
    }
  },
  "globe": {
    "band": {
      "space": { "$value": 3, "$description": "z0-3: dotted globe + arcs" },
      "continent": { "$value": 7, "$description": "z3-7: labeled pins, arcs fade" },
      "city": { "$value": 13, "$description": "z7-13: themed city style" }
    }
  },
  "layout": {
    "measure": { "$value": "68ch", "$description": "body text measure" },
    "radius": {
      "plate": { "$value": "6px", "$description": "signage plates" },
      "card": { "$value": "14px" },
      "pill": { "$value": "999px" }
    }
  }
}
